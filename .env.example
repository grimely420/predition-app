# CF Benchmarks API credentials (required to use CF Benchmarks as a price source)
# Get a license/API key from https://www.cfbenchmarks.com/about/contact
CF_API_USERNAME=your_cfbenchmarks_username
CF_API_PASSWORD=your_cfbenchmarks_api_key_or_password

# Alternative variable names (also accepted)
# CFBENCHMARKS_API_USERNAME=your_cfbenchmarks_username
# CFBENCHMARKS_API_PASSWORD=your_cfbenchmarks_api_key_or_password
